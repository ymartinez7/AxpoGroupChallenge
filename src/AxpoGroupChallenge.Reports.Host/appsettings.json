{
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ]
  },
  "WorkerExecutionOptions": {
    "ExtractionIntervalMinutes": 10
  },
  "ReportFileOptions": {
    "OutputDirectoryPath": "C:\\PowerPositionReports",
    "TimeZone": "GMT Standard Time",
    "FileNameFormat": "PowerPosition_{0:yyyyMMdd}_{1:HHmm}.csv"
  }
}
